FROM python:3.11-slim
LABEL maintainer="AIOS Lab <admin@socialbeesai.com>"
LABEL description="mem0 — Agent memory layer backed by Qdrant"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server.py .

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
