FROM python:3.11-slim
LABEL maintainer="AIOS Lab <admin@socialbeesai.com>"
LABEL description="knowledge — Document ingestion + wiki compilation agent"

WORKDIR /app

RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p wiki/concepts wiki/entities wiki/sources

CMD ["python3", "ingest-file.py"]
